{
    "id": "feedback",
    "name": "Feedback Loop",
    "category": "postprocess",
    "description": "Recursive feedback with zoom, rotation, and hue shift trails",
    "params": [
        { "name": "fb_decay", "label": "Decay Rate", "type": "float", "default": 0.05, "min": 0.01, "max": 0.5, "step": 0.01 },
        { "name": "fb_zoom", "label": "Zoom", "type": "float", "default": 0.99, "min": 0.95, "max": 1.05, "step": 0.001 },
        { "name": "fb_rotation", "label": "Rotation", "type": "float", "default": 0.01, "min": -0.1, "max": 0.1, "step": 0.005 },
        { "name": "fb_hue_shift", "label": "Hue Shift", "type": "float", "default": 0.01, "min": 0.0, "max": 0.1, "step": 0.005 },
        { "name": "fb_mix", "label": "Feedback Mix", "type": "float", "default": 0.85, "min": 0.0, "max": 1.0, "step": 0.01 }
    ]
}
