    { "name": "intensity", "label": "Intensity", "type": "float", "default": 1.0, "min": 0.0, "max": 3.0, "step": 0.05 },
    { "name": "streak_length", "label": "Streak Length", "type": "float", "default": 1.0, "min": 0.0, "max": 2.0, "step": 0.05 },
    { "name": "ghost_count", "label": "Ghost Count", "type": "float", "default": 3.0, "min": 0.0, "max": 6.0, "step": 1.0 },
    { "name": "audio_drive", "label": "Audio Drive", "type": "float", "default": 1.0, "min": 0.0, "max": 2.0, "step": 0.05 }
