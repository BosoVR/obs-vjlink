    { "name": "base_color_r", "label": "Color R", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "step": 0.01 },
    { "name": "base_color_g", "label": "Color G", "type": "float", "default": 0.15, "min": 0.0, "max": 1.0, "step": 0.01 },
    { "name": "base_color_b", "label": "Color B", "type": "float", "default": 0.7, "min": 0.0, "max": 1.0, "step": 0.01 }
