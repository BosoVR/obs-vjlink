{
    "effect_id": "ascii_art",
    "name": "ASCII Art",
    "category": "glitch",
    "role": "filter",
    "requires_input": true,
    "performance_group": "post_glitch",
    "description": "Character-map rendering with audio-reactive density and terminal-green option",
    "author": "VJLink",
    "params": [
        { "id": "char_size", "name": "Char Size", "type": "float", "default": 8.0, "min": 4.0, "max": 24.0, "step": 1.0 },
        { "id": "color_preserve", "name": "Color Preserve", "type": "float", "default": 0.5, "min": 0.0, "max": 1.0, "step": 0.05 },
        { "id": "contrast", "name": "Contrast", "type": "float", "default": 1.5, "min": 0.5, "max": 3.0, "step": 0.1 },
        { "id": "bg_brightness", "name": "BG Brightness", "type": "float", "default": 0.05, "min": 0.0, "max": 0.3, "step": 0.01 },
        { "id": "audio_drive", "name": "Audio Drive", "type": "float", "default": 0.8, "min": 0.0, "max": 2.5, "step": 0.05 },
        { "id": "glyph_sharpness", "name": "Glyph Sharpness", "type": "float", "default": 0.7, "min": 0.0, "max": 1.0, "step": 0.05 }
    ]
}
