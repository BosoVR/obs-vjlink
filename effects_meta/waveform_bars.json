        { "name": "sensitivity", "label": "Sensitivity", "type": "float", "default": 5.0, "min": 1.0, "max": 10.0, "step": 0.5 },
        { "name": "mirror", "label": "Mirror Mode", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "step": 1.0 }
    ]
