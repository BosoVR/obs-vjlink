{
    "vjlink_version": "1.0",
    "preset_name": "Neon Tunnel",
    "category": "tunnel",
    "description": "Classic tunnel with neon colors driven by bass",
    "effect_chain": [
        {
            "effect_id": "tunnel_classic",
            "blend_mode": "normal",
            "params": {
                "tunnel_speed": 1.5,
                "rotation_speed": 0.3,
                "ring_count": 12.0,
                "color_intensity": 1.5
            },
            "animations": [
                { "param": "tunnel_speed", "source": "audio_band", "config": { "band": "bass", "scale": 2.0, "offset": 0.5 } },
                { "param": "rotation_speed", "source": "lfo", "config": { "waveform": "sine", "freq": 0.1, "min": -0.5, "max": 0.5 } }
            ]
        },
        {
            "effect_id": "color_grade",
            "blend_mode": "normal",
            "params": {
                "pp_saturation": 1.3,
                "pp_contrast": 1.1,
                "pp_vignette": 0.3
            }
        }
    ],
    "lfo_config": [
        { "waveform": "sine", "freq": 0.1, "sync_to_beat": false }
    ]
}
