{
    "vjlink_version": "1.0",
    "preset_name": "Sacred Pulse",
    "category": "geometric",
    "description": "Sacred geometry pattern with beat-synced rotation and glow",
    "effect_chain": [
        {
            "effect_id": "sacred_geometry",
            "blend_mode": "normal",
            "params": {
                "pattern_scale": 3.0,
                "line_width": 0.015,
                "rotation_speed": 0.05,
                "layers": 4.0
            },
            "animations": [
                { "param": "line_width", "source": "beat_env", "config": { "decay": 2.0, "scale": 0.03 } },
                { "param": "rotation_speed", "source": "audio_band", "config": { "band": "lowmid", "scale": 0.3, "offset": 0.05 } }
            ]
        },
        {
            "effect_id": "color_grade",
            "blend_mode": "normal",
            "params": {
                "pp_saturation": 1.2,
                "pp_vignette": 0.4
            }
        }
    ]
}
