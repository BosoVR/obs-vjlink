{
    "vjlink_version": "1.0",
    "preset_name": "Glitch Machine",
    "category": "glitch",
    "description": "RGB split + datamosh chain triggered by beats",
    "effect_chain": [
        {
            "effect_id": "rgb_split",
            "blend_mode": "normal",
            "params": {
                "split_amount": 0.008,
                "split_angle": 0.0,
                "audio_drive": 3.0,
                "aberration_type": 0.0
            },
            "animations": [
                { "param": "split_angle", "source": "lfo", "config": { "waveform": "sawtooth", "freq": 0.2, "min": 0.0, "max": 6.28 } }
            ]
        },
        {
            "effect_id": "datamosh",
            "blend_mode": "normal",
            "params": {
                "block_size": 12.0,
                "intensity": 0.4,
                "displacement": 0.04,
                "noise_amount": 0.2
            },
            "animations": [
                { "param": "intensity", "source": "beat_env", "config": { "decay": 3.0, "scale": 0.8 } }
            ]
        }
    ]
}
